{
  "expo": {
    "name": "Bite Insight",
    "slug": "gcahill",
    "version": "1.5.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "biteinsight",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.biteinsight.app",
      "buildNumber": "6",
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-tinted.png"
      },
      "associatedDomains": [
        "applinks:biteinsight.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "BiteInsight needs camera access to scan food labels and barcodes.",
        "NSPhotoLibraryUsageDescription": "BiteInsight needs access to your photo library.",
        "NSFaceIDUsageDescription": "BiteInsight uses Face ID to let you sign in quickly and securely."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#e2f1ee"
      },
      "package": "com.biteinsightapp.gcahill",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_FINGERPRINT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "biteinsight.app",
              "pathPrefix": "/recipes/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "BiteInsight needs camera access to scan food labels and barcodes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "BiteInsight needs access to your photo library to set your profile picture."
        }
      ],
      "expo-sqlite",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "BiteInsight uses Face ID to let you sign in quickly and securely."
        }
      ],
      "expo-localization",
      "expo-video",
      "expo-image",
      "expo-sharing",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "ndkVersion": "27.1.12297006"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#e2f1ee",
          "android": {
            "image": "./assets/images/splash-icon-android.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#e2f1ee"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "dcda6136-ab96-4037-8f10-40fc2a71d25a"
      }
    },
    "owner": "biteinsightapp",
    "runtimeVersion": "1.0.1",
    "updates": {
      "url": "https://u.expo.dev/dcda6136-ab96-4037-8f10-40fc2a71d25a"
    }
  }
}
